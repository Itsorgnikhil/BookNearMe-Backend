git add src/main/resources/application.yaml .env.example
# Server Config
SERVER_PORT=9000
SERVER_CONTEXT_PATH=/api/v1

# Primary Database Connection
DB_URL=jdbc:postgresql://localhost:5432/staynest_db
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_DDL_AUTO=update

# JPA / Hibernate Config
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# Vector Store Connection (pgvector)
VECTOR_DB_URL=jdbc:postgresql://localhost:5433/staynest_db
VECTOR_DB_USERNAME=postgres
VECTOR_DB_PASSWORD=your_vector_db_password

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Security Config
JWT_SECRET_KEY=your_jwt_secret_key_here_must_be_at_least_256_bits_long

# Frontend Config
FRONTEND_URL=http://localhost:3000

# Stripe Config
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Swagger / SpringDoc Config
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true
